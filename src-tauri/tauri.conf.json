{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileNavigation",
  "version": "0.1.5",
  "identifier": "dev.filenavigation.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FileNavigation",
        "decorations": false,
        "shadow": true,
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Fast local directory file search",
    "longDescription": "FileNavigation is a cross-platform desktop app for searching files inside a selected local directory.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
